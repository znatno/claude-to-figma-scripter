{
  "preset": "material",
  "fontFamily": "Roboto",
  "fontWeights": {
    "regular":  "Regular",
    "semiBold": "Medium",
    "bold":     "Bold"
  },
  "colors": {
    "bg":             { "r": 0.98,  "g": 0.98,  "b": 0.98  },
    "surface":        { "r": 1,     "g": 1,     "b": 1     },
    "label":          { "r": 0.13,  "g": 0.13,  "b": 0.13  },
    "labelSecondary": { "r": 0.38,  "g": 0.38,  "b": 0.38  },
    "separator":      { "r": 0.88,  "g": 0.88,  "b": 0.88  },
    "blue":           { "r": 0.098, "g": 0.463, "b": 0.824 },
    "green":          { "r": 0.298, "g": 0.686, "b": 0.314 },
    "red":            { "r": 0.957, "g": 0.263, "b": 0.212 },
    "orange":         { "r": 1,     "g": 0.596, "b": 0     },
    "gray":           { "r": 0.62,  "g": 0.62,  "b": 0.62  },
