    "body":       { "size": 16, "weight": "Regular","lineHeight": 24 },
    "callout":    { "size": 14, "weight": "Regular","lineHeight": 20 },
    "subhead":    { "size": 14, "weight": "Medium", "lineHeight": 20 },
    "footnote":   { "size": 12, "weight": "Regular","lineHeight": 16 },
